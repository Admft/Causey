# Optional self-hosted ingest runner (VPS / local Docker).
# Prefer GitHub Actions (.github/workflows/ingest.yml) unless you need
# a machine that stays up outside GitHub's network.
FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY ingestion ./ingestion
COPY lib ./lib
COPY tsconfig.json ./

# Expect secrets via env at runtime:
#   NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
CMD ["npm", "run", "scrape:all"]
