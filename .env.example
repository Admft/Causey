# ---------------------------------------------------------------------------
# Causey app environment. Every value is optional: the app boots with an
# empty .env and runs entirely on seeded mock data (DATA_SOURCE defaults to
# "mock" and no network calls are made).
# ---------------------------------------------------------------------------

# 'mock' (default) reads /data/seed JSON in-process.
# 'supabase' runs against a Supabase project via lib/data/supabase.ts.
DATA_SOURCE=mock

# Required only when DATA_SOURCE=supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Used by `npm run seed:supabase` and `npm run scrape:tla`
# to write rows (seeding, draft ingestion). Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=
